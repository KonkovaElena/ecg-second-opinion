# ─── ECG Second Opinion — Environment Variables ─────────────────────
# Copy to .env and adjust values. Never commit .env to version control.

# Server
PORT=3100
HOST=0.0.0.0
NODE_ENV=development
PUBLIC_BASE_URL=http://127.0.0.1:3100

# API Prefixes
API_PREFIX=/api/v1
INTERNAL_API_PREFIX=/api/internal

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Operator Auth (x-api-key header)
# CHANGE THIS in production — default is a dev-only placeholder; use at least 32 characters
ECG_OPERATOR_API_TOKEN=ecg-operator-dev-token-change-me-0001

# Internal Worker Auth (Bearer token for inference callbacks)
# CHANGE THIS in production — default is a dev-only placeholder; use at least 32 characters
ECG_INTERNAL_API_TOKEN=ecg-internal-dev-token-change-me-0001

# Reviewer JWT Auth (HS256)
# CHANGE THIS in production — must be ≥32 bytes for HMAC-SHA256
ECG_REVIEWER_JWT_SECRET=ecg-reviewer-jwt-secret-change-me-00000000000000000000000000000000
ECG_REVIEWER_JWT_ISSUER=ecg-second-opinion
ECG_REVIEWER_JWT_AUDIENCE=ecg-second-opinion-api
ECG_REVIEWER_ALLOWED_ROLES=Cardiologist,Electrophysiologist
ECG_AUTH_CLOCK_SKEW_SECONDS=60
